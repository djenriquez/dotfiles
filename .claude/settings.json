{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "100000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "ENABLE_LSP_TOOL": "1",
    "MAX_THINKING_TOKENS": "31999",
    "PATH": "__PATH__"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(./hack/:*)",
      "Bash(cat:*)",
      "Bash(cwebp:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(grep:*)",
      "Bash(helm:*)",
      "Bash(kubectl:*)",
      "Bash(kustomize:*)",
      "Bash(ls:*)",
      "Bash(mise:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(sed:*)",
      "Bash(terraform:*)",
      "Bash(yarn:*)",
      "WebFetch(domain:*)",
      "mcp__deepwiki"
    ],
    "deny": [
      "mcp__codex__codex-reply"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": []
  },
  "model": "opus",
  "hooks": {
    "PreCompact": [],
    "SessionStart": []
  },
  "enabledPlugins": {
    "abatilo-core@abatilo-plugins": true,
    "bits@bits-plugins": true,
    "gopls-lsp@claude-plugins-official": true,
    "spec-review@djenriquez-plugins": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
